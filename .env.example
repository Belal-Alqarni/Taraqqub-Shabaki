TARAQQUB_DB_PATH=./data/taraqqub.db
# Optional for persistent hosted deployments:
# TARAQQUB_DATABASE_URL=postgresql://user:password@host/database?sslmode=require
TARAQQUB_MONITOR_INTERVAL=10
TARAQQUB_ENABLE_SELF_HEALING=false
TARAQQUB_ENV=development
TARAQQUB_ADMIN_USERNAME=admin
TARAQQUB_ADMIN_PASSWORD=Taraqqub!2026
TARAQQUB_SESSION_HOURS=12
TARAQQUB_SECURE_COOKIES=false
TARAQQUB_ALLOW_SIGNUP=false
TARAQQUB_SCAN_NETWORK=192.168.100.0/24
TARAQQUB_SCAN_GATEWAY=192.168.100.1
