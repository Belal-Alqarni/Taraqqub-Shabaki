FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends iputils-ping nmap \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /agent
COPY agent/taraqqub_agent.py .

RUN useradd --create-home --uid 10001 taraqqub-agent \
    && chown -R taraqqub-agent:taraqqub-agent /agent

USER taraqqub-agent

CMD ["python", "-B", "taraqqub_agent.py"]
